# AquaVibe Studio local environment template
# Copy this file to .env and fill in your real Supabase values.

# Frontend Supabase config
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_USE_SUPABASE=false

# Server-only admin config
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# Optional admin protection for serverless endpoints
# Set both of these to the same value if you want the frontend to send the header in dev/preview.
# ADMIN_API_SECRET=your-admin-secret
# VITE_ADMIN_API_SECRET=your-admin-secret